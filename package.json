  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit",
    "test:unit": "tsc -p tsconfig.test.json && node -e \"const fs=require('fs'); fs.mkdirSync('.codex-test-dist',{ recursive: true }); fs.writeFileSync('.codex-test-dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}');\" && node .codex-test-dist/tests/run-unit-tests.js",
    "lint": "oxlint",
    "format": "oxfmt \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --linked --schema public > lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@faker-js/faker": "^10.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
